#compdef fpdev
# Zsh completion script for fpdev
# Install: fpath=(~/.zsh/completions $fpath) && autoload -Uz compinit && compinit
# Or copy to /usr/share/zsh/site-functions/_fpdev

_fpdev() {
    local -a commands fpc_commands lazarus_commands cross_commands package_commands
    local -a package_repo_commands project_commands

    commands=(
        'fpc:FPC 版本管理'
        'lazarus:Lazarus IDE 管理'
        'cross:交叉编译管理'
        'package:包管理'
        'project:项目管理'
        'system:系统域命令'
    )

    fpc_commands=(
        'install:安装 FPC 版本'
        'uninstall:卸载 FPC 版本'
        'list:列出 FPC 版本'
        'use:切换 FPC 版本'
        'current:显示当前版本'
        'show:显示版本详情'
        'doctor:诊断安装'
        'test:测试安装'
        'verify:校验安装'
        'auto-install:从项目配置自动安装'
        'update:更新版本'
        'update-manifest:刷新远端清单缓存'
        'cache:缓存管理'
        'policy:FPC 策略检查'
        'help:显示帮助'
    )

    lazarus_commands=(
        'install:安装 Lazarus'
        'uninstall:卸载 Lazarus'
        'list:列出版本'
        'use:切换版本'
        'current:显示当前版本'
        'show:显示详情'
        'run:启动 IDE'
        'test:测试安装'
        'doctor:诊断'
        'update:更新'
        'configure:配置'
        'help:显示帮助'
    )

    cross_commands=(
        'list:列出目标'
        'install:安装目标'
        'uninstall:卸载目标'
        'enable:启用目标'
        'disable:禁用目标'
        'show:显示详情'
        'test:测试目标'
        'configure:配置目标'
        'update:更新目标'
        'clean:清理目标'
        'build:构建交叉编译器'
        'doctor:诊断环境'
        'help:显示帮助'
    )

    package_commands=(
        'install:安装包'
        'uninstall:卸载包'
        'update:更新包'
        'list:列出包'
        'search:搜索包'
        'info:包信息'
        'publish:发布包'
        'clean:清理'
        'install-local:本地安装'
        'repo:仓库管理'
        'deps:依赖树'
        'why:依赖路径'
        'help:显示帮助'
    )

    package_repo_commands=(
        'add:添加仓库'
        'list:列出仓库'
        'remove:移除仓库'
        'update:更新仓库'
    )

    local -a system_commands system_repo_commands
    local -a system_env_commands system_config_commands system_index_commands
    local -a system_cache_commands system_perf_commands system_toolchain_commands
    local -a fpc_policy_commands

    system_commands=(
        'help:根帮助'
        'version:版本信息'
        'repo:仓库管理'
        'config:配置管理'
        'env:环境信息'
        'index:索引管理'
        'cache:缓存管理'
        'doctor:系统诊断'
        'perf:性能监控'
        'toolchain:工具链检查'
    )

    system_env_commands=(
        'data-root:数据根目录'
        'vars:环境变量'
        'path:PATH 配置'
        'export:导出环境'
        'hook:生成 shell hook'
        'resolve:解析当前生效版本'
    )

    system_repo_commands=(
        'add:添加仓库'
        'list:列出仓库'
        'remove:移除仓库'
        'show:显示仓库'
        'use:选择当前仓库'
        'versions:查看版本'
        'help:显示帮助'
    )

    system_config_commands=(
        'show:显示配置'
        'get:读取配置项'
        'set:设置配置项'
        'export:导出配置'
        'import:导入配置'
        'list:列出工具链'
    )

    system_index_commands=(
        'status:显示索引状态'
        'show:显示索引详情'
        'update:刷新索引'
    )

    system_cache_commands=(
        'status:显示缓存状态'
        'stats:显示缓存统计'
        'path:显示缓存路径'
    )

    system_perf_commands=(
        'clear:清空性能数据'
        'report:输出性能报告'
        'save:保存性能数据'
        'summary:输出性能摘要'
    )

    system_toolchain_commands=(
        'check:输出工具链检查结果'
        'self-test:运行工具链自检'
        'fetch:拉取工具链工件'
        'extract:解压本地归档'
        'ensure-source:准备本地源码'
        'import-bundle:导入离线捆绑包'
    )

    fpc_policy_commands=(
        'check:检查 FPC 版本策略'
    )

    project_commands=(
        'new:创建项目'
        'list:列出模板'
        'info:模板信息'
        'build:构建项目'
        'run:运行项目'
        'test:测试项目'
        'clean:清理项目'
        'template:模板管理'
        'help:显示帮助'
    )

    local -a fpc_versions cross_targets project_templates

    fpc_versions=('3.2.2' '3.2.0' '3.0.4' 'main' 'trunk')

    cross_targets=(
        'win64:Windows 64-bit'
        'win32:Windows 32-bit'
        'linux-arm:ARM Linux'
        'linux-arm64:ARM64 Linux'
        'darwin-x64:macOS Intel'
        'darwin-arm64:macOS Apple Silicon'
        'android-arm:Android ARM'
        'android-arm64:Android ARM64'
    )

    project_templates=('console' 'gui' 'library' 'package' 'service' 'game')

    case "${words[2]}" in
        fpc)
            case "${words[3]}" in
                install|uninstall|use|show|test|verify|update)
                    _describe 'version' fpc_versions
                    ;;
                cache)
                    _describe 'cache command' '(list stats clean path)'
                    ;;
                policy)
                    _describe 'policy command' '(check)'
                    ;;
                *)
                    _describe 'fpc command' fpc_commands
                    ;;
            esac
            ;;
        lazarus)
            _describe 'lazarus command' lazarus_commands
            ;;
        cross)
            case "${words[3]}" in
                install|uninstall|enable|disable|show|test|configure|update|clean|build)
                    _describe 'target' cross_targets
                    ;;
                *)
                    _describe 'cross command' cross_commands
                    ;;
            esac
            ;;
        package)
            case "${words[3]}" in
                repo)
                    _describe 'package repo command' package_repo_commands
                    ;;
                *)
                    _describe 'package command' package_commands
                    ;;
            esac
            ;;
        system)
            case "${words[3]}" in
                config)
                    _describe 'system config command' system_config_commands
                    ;;
                index)
                    _describe 'system index command' system_index_commands
                    ;;
                cache)
                    _describe 'system cache command' system_cache_commands
                    ;;
                perf)
                    _describe 'system perf command' system_perf_commands
                    ;;
                toolchain)
                    _describe 'system toolchain command' system_toolchain_commands
                    ;;
                env)
                    _describe 'system env command' system_env_commands
                    ;;
                repo)
                    _describe 'system repo command' system_repo_commands
                    ;;
                *)
                    _describe 'system command' system_commands
                    ;;
            esac
            ;;
        project)
            case "${words[3]}" in
                new|info)
                    _describe 'template' project_templates
                    ;;
                template)
                    _describe 'template command' '(list install remove update)'
                    ;;
                *)
                    _describe 'project command' project_commands
                    ;;
            esac
            ;;
        *)
            _describe 'command' commands
            ;;
    esac
}

_fpdev "$@"
